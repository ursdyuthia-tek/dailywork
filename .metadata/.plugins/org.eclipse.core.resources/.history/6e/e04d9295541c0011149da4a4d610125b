package basics;

public class Demo1 {

    public static void main(String[] args) {
        int count = 5;

        // Pyramid with *
        for (int i = count; i >= 1; i--) {
            for (int j = 0; j < i; j++) {
                System.out.print("* ");
            }
            System.out.println();
        }

        // Pyramid with $
        for (int i = count; i >= 1; i--) {
            for (int j = 0; j < i; j++) {
                System.out.print("$ ");
            }
            System.out.println();
        }
    }
}
